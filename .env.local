# ==============================================================================
# JurisAI — Environment Variables
# ==============================================================================
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and must NEVER be committed. This file (.env.example) contains
# no real secrets — only documented placeholders.
#
# Variables prefixed NEXT_PUBLIC_ are inlined into the client-side JS bundle
# at build time and are visible to anyone in the browser. Every other
# variable is server-only and must stay that way.
#
# Validated at startup by: src/core/config/env.ts
# ==============================================================================


# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------

# Public. Used for absolute URL generation (metadata, OG tags, email links).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# Supabase (Auth, Database, Storage, Realtime)
# ------------------------------------------------------------------------------

# Public. Safe to expose — Supabase's anon key is designed for client use and
# is enforced by Row Level Security policies, not by secrecy.
NEXT_PUBLIC_SUPABASE_URL=https://vmmlhxdnhpfmesdmppbf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZtbWxoeGRuaHBmbWVzZG1wcGJmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM3NTM1NjMsImV4cCI6MjA5OTMyOTU2M30.Np2wB1c7WTa5-EbPjijDQgXzFRhbvKhMq9eOZWRajEA

# SERVER-ONLY. Bypasses Row Level Security entirely. Used exclusively in
# trusted server contexts (Edge Functions, admin operations, background jobs).
# Must never be sent to the client or logged.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZtbWxoeGRuaHBmbWVzZG1wcGJmIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4Mzc1MzU2MywiZXhwIjoyMDk5MzI5NTYzfQ.rSqgUrbjCDJU55z3FX8Y2bQHMNnO6MwACSX3iZd3u5M


# ------------------------------------------------------------------------------
# AI Providers
# ------------------------------------------------------------------------------

# SERVER-ONLY. Consumed exclusively inside src/core/ai/providers/*.
# Never imported or referenced from any client component.
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Public. Non-secret feature flag read by src/core/ai/ai.service.ts to select
# the default provider (e.g. "openai" | "gemini"). Not a credential.
NEXT_PUBLIC_AI_DEFAULT_PROVIDER=openai


# ------------------------------------------------------------------------------
# Payments — reserved, not yet consumed (Task: Payments module)
# ------------------------------------------------------------------------------
